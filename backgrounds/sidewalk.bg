{
  "_type": "fyeox_background",
  "_version": "0.5.0",
  "id": "sidewalk",
  "name": "Sidewalk / Sidewalk Scene",
  "author": "unixabg@gmail.com",
  "created": "2026-04-23",
  "svg_component": "()=>(\n<g>\n  {/* Sky */}\n  <defs>\n    <linearGradient id=\"skyG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#87CEEB\"/>\n      <stop offset=\"100%\" stopColor=\"#B0E0FF\"/>\n    </linearGradient>\n  </defs>\n  <rect width=\"540\" height=\"320\" fill=\"url(#skyG)\"/>\n  {/* Sun */}\n  <circle cx=\"460\" cy=\"55\" r=\"32\" fill=\"#FFE900\" opacity=\"0.9\"/>\n  <circle cx=\"460\" cy=\"55\" r=\"26\" fill=\"#FFD700\"/>\n  {/* Clouds */}\n  <ellipse cx=\"90\" cy=\"45\" rx=\"45\" ry=\"20\" fill=\"white\" opacity=\"0.85\"/>\n  <ellipse cx=\"120\" cy=\"38\" rx=\"35\" ry=\"18\" fill=\"white\" opacity=\"0.85\"/>\n  <ellipse cx=\"65\" cy=\"52\" rx=\"30\" ry=\"14\" fill=\"white\" opacity=\"0.75\"/>\n  <ellipse cx=\"310\" cy=\"60\" rx=\"50\" ry=\"18\" fill=\"white\" opacity=\"0.75\"/>\n  <ellipse cx=\"345\" cy=\"52\" rx=\"38\" ry=\"16\" fill=\"white\" opacity=\"0.75\"/>\n  {/* Buildings in background */}\n  <rect x=\"0\" y=\"80\" width=\"80\" height=\"130\" fill=\"#C4A882\" stroke=\"#8B7355\" strokeWidth=\"2\"/>\n  <rect x=\"10\" y=\"90\" width=\"18\" height=\"22\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"35\" y=\"90\" width=\"18\" height=\"22\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"10\" y=\"122\" width=\"18\" height=\"22\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"35\" y=\"122\" width=\"18\" height=\"22\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"22\" y=\"148\" width=\"36\" height=\"62\" fill=\"#8B6914\"/>\n  <rect x=\"80\" y=\"95\" width=\"100\" height=\"115\" fill=\"#D4B896\" stroke=\"#8B7355\" strokeWidth=\"2\"/>\n  <rect x=\"88\" y=\"105\" width=\"20\" height=\"24\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"116\" y=\"105\" width=\"20\" height=\"24\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"144\" y=\"105\" width=\"20\" height=\"24\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"96\" y=\"145\" width=\"28\" height=\"65\" fill=\"#7A5C1E\"/>\n  <rect x=\"420\" y=\"70\" width=\"120\" height=\"140\" fill=\"#C4A882\" stroke=\"#8B7355\" strokeWidth=\"2\"/>\n  <rect x=\"430\" y=\"82\" width=\"22\" height=\"26\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"460\" y=\"82\" width=\"22\" height=\"26\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"490\" y=\"82\" width=\"22\" height=\"26\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"430\" y=\"118\" width=\"22\" height=\"26\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"460\" y=\"118\" width=\"22\" height=\"26\" fill=\"#7ABAFF\" opacity=\"0.6\"/>\n  <rect x=\"442\" y=\"152\" width=\"40\" height=\"58\" fill=\"#8B6914\"/>\n  {/* Crowd suggestion */}\n  {[30,60,95,130,165,200,235,270,310,350,390,430,465,500].map((x,i)=>(\n    <g key={i}>\n      <circle cx={x} cy={200} r={10+((i*7)%6)} fill={[\"#E8C49A\",\"#8B4513\",\"#F4C878\",\"#C67C52\",\"#FFD9A0\",\"#A0522D\"][i%6]}/>\n      <rect x={x-7} y={208} width={14} height={18} rx=\"3\" fill={[\"#FF6B6B\",\"#4ECDC4\",\"#45B7D1\",\"#96CEB4\",\"#FFEAA7\",\"#DDA0DD\"][i%6]}/>\n    </g>\n  ))}\n  {/* Fence */}\n  {[0,18,36,54,72,90,108,126,144,162,180,198,216,234,252,270,288,306,324,342,360,378,396,414,432,450,468,486,504,522].map((x,i)=>(\n    <g key={i}>\n      <rect x={x+2} y={220} width={8} height={40} rx=\"2\" fill=\"white\" stroke=\"#DDD\" strokeWidth=\"0.5\"/>\n      <polygon points={`${x+2},220 ${x+6},212 ${x+10},220`} fill=\"white\" stroke=\"#DDD\" strokeWidth=\"0.5\"/>\n    </g>\n  ))}\n  {/* Sidewalk / porch */}\n  <rect x=\"0\" y=\"255\" width=\"540\" height=\"65\" fill=\"#C8B89A\"/>\n  <rect x=\"0\" y=\"253\" width=\"540\" height=\"5\" fill=\"#A89070\"/>\n  {/* Sidewalk lines */}\n  {[90,180,270,360,450].map((x,i)=>(\n    <line key={i} x1={x} y1=\"258\" x2={x} y2=\"320\" stroke=\"#B8A880\" strokeWidth=\"1.5\" strokeDasharray=\"4,3\"/>\n  ))}\n  {/* Grass strip */}\n  <rect x=\"0\" y=\"215\" width=\"540\" height=\"42\" fill=\"#4A8B3F\"/>\n  <rect x=\"0\" y=\"213\" width=\"540\" height=\"5\" fill=\"#3A7A2F\"/>\n  {/* Berry bushes */}\n  <ellipse cx=\"200\" cy=\"225\" rx=\"32\" ry=\"20\" fill=\"#2D6A1F\"/>\n  <ellipse cx=\"185\" cy=\"220\" rx=\"22\" ry=\"16\" fill=\"#3A8A28\"/>\n  <ellipse cx=\"218\" cy=\"218\" rx=\"20\" ry=\"15\" fill=\"#358022\"/>\n  {[193,204,212,188,208,197,215].map((x,i)=>\n    <circle key={i} cx={x} cy={218+(i%3)*4} r={3.5} fill=\"#CC2244\" opacity=\"0.9\"/>\n  )}\n  <ellipse cx=\"370\" cy=\"228\" rx=\"28\" ry=\"18\" fill=\"#2D6A1F\"/>\n  <ellipse cx=\"355\" cy=\"223\" rx=\"20\" ry=\"14\" fill=\"#3A8A28\"/>\n  <ellipse cx=\"386\" cy=\"221\" rx=\"18\" ry=\"13\" fill=\"#358022\"/>\n  {[360,370,380,365,377,356,383].map((x,i)=>\n    <circle key={i} cx={x} cy={222+(i%3)*4} r={3} fill=\"#CC2244\" opacity=\"0.9\"/>\n  )}\n</g>)"
}
