{
  "_type": "fyeox_background",
  "_version": "0.5.0",
  "id": "park",
  "name": "Park / Outdoors",
  "author": "unixabg@gmail.com",
  "created": "2026-04-23",
  "svg_component": "()=>(\n<g>\n  {/* Sky */}\n  <defs>\n    <linearGradient id=\"parkSkyG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#5BA3D9\"/>\n      <stop offset=\"100%\" stopColor=\"#A8D8F0\"/>\n    </linearGradient>\n    <linearGradient id=\"grassG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#4A9E3F\"/>\n      <stop offset=\"100%\" stopColor=\"#3A7A2F\"/>\n    </linearGradient>\n  </defs>\n  <rect width=\"540\" height=\"320\" fill=\"url(#parkSkyG)\"/>\n  {/* Clouds */}\n  <ellipse cx=\"100\" cy=\"50\" rx=\"55\" ry=\"24\" fill=\"white\" opacity=\"0.9\"/>\n  <ellipse cx=\"135\" cy=\"40\" rx=\"42\" ry=\"20\" fill=\"white\" opacity=\"0.9\"/>\n  <ellipse cx=\"70\" cy=\"58\" rx=\"35\" ry=\"16\" fill=\"white\" opacity=\"0.8\"/>\n  <ellipse cx=\"380\" cy=\"65\" rx=\"60\" ry=\"22\" fill=\"white\" opacity=\"0.85\"/>\n  <ellipse cx=\"420\" cy=\"55\" rx=\"45\" ry=\"20\" fill=\"white\" opacity=\"0.85\"/>\n  <ellipse cx=\"350\" cy=\"70\" rx=\"38\" ry=\"16\" fill=\"white\" opacity=\"0.75\"/>\n  {/* Sun */}\n  <circle cx=\"480\" cy=\"55\" r=\"36\" fill=\"#FFE900\" opacity=\"0.95\"/>\n  <circle cx=\"480\" cy=\"55\" r=\"28\" fill=\"#FFD700\"/>\n  {/* Far trees */}\n  <ellipse cx=\"30\" cy=\"155\" rx=\"36\" ry=\"50\" fill=\"#2D6B1F\"/>\n  <ellipse cx=\"20\" cy=\"145\" rx=\"28\" ry=\"38\" fill=\"#3A8A28\"/>\n  <rect x=\"24\" y=\"190\" width=\"12\" height=\"30\" fill=\"#6B4226\"/>\n  <ellipse cx=\"510\" cy=\"148\" rx=\"34\" ry=\"48\" fill=\"#2D6B1F\"/>\n  <ellipse cx=\"522\" cy=\"140\" rx=\"26\" ry=\"36\" fill=\"#3A8A28\"/>\n  <rect x=\"504\" y=\"182\" width=\"12\" height=\"28\" fill=\"#6B4226\"/>\n  <ellipse cx=\"250\" cy=\"135\" rx=\"30\" ry=\"44\" fill=\"#256B18\"/>\n  <ellipse cx=\"240\" cy=\"128\" rx=\"24\" ry=\"34\" fill=\"#3A8A28\"/>\n  <rect x=\"244\" y=\"168\" width=\"10\" height=\"32\" fill=\"#6B4226\"/>\n  {/* Distant hills */}\n  <ellipse cx=\"160\" cy=\"195\" rx=\"110\" ry=\"55\" fill=\"#5AAA3A\" opacity=\"0.6\"/>\n  <ellipse cx=\"370\" cy=\"200\" rx=\"130\" ry=\"60\" fill=\"#4E9A30\" opacity=\"0.6\"/>\n  {/* Path / dirt trail */}\n  <path d=\"M200 320 Q240 280 260 240 Q275 210 270 195\" stroke=\"#C4A882\" strokeWidth=\"28\" fill=\"none\" strokeLinecap=\"round\" opacity=\"0.7\"/>\n  <path d=\"M200 320 Q240 280 260 240 Q275 210 270 195\" stroke=\"#D4B896\" strokeWidth=\"20\" fill=\"none\" strokeLinecap=\"round\" opacity=\"0.5\"/>\n  {/* Ground / grass */}\n  <rect x=\"0\" y=\"218\" width=\"540\" height=\"102\" fill=\"url(#grassG)\"/>\n  <rect x=\"0\" y=\"216\" width=\"540\" height=\"5\" fill=\"#3A7A2F\"/>\n  {/* Grass tufts */}\n  {[[40,225],[120,228],[200,222],[320,226],[420,224],[500,228],[70,232],[280,230],[460,225]].map(([x,y],i)=>(\n    <g key={i}>\n      <path d={`M${x} ${y} Q${x-5} ${y-10} ${x-3} ${y}`} stroke=\"#2D6A1F\" strokeWidth=\"1.5\" fill=\"none\"/>\n      <path d={`M${x} ${y} Q${x} ${y-12} ${x+2} ${y}`} stroke=\"#3A8A28\" strokeWidth=\"1.5\" fill=\"none\"/>\n      <path d={`M${x} ${y} Q${x+5} ${y-9} ${x+3} ${y}`} stroke=\"#2D6A1F\" strokeWidth=\"1.5\" fill=\"none\"/>\n    </g>\n  ))}\n  {/* Flowers */}\n  {[[90,238],[190,234],[340,240],[480,235],[150,242],[400,237]].map(([x,y],i)=>(\n    <g key={i}>\n      <circle cx={x} cy={y} r={5} fill={[\"#FF6B6B\",\"#FFE900\",\"#FF88CC\",\"#FF6B6B\",\"#FFE900\",\"#AADDFF\"][i]}/>\n      <circle cx={x} cy={y} r={2.5} fill=\"#FFE900\"/>\n    </g>\n  ))}\n  {/* Park bench */}\n  <rect x=\"370\" y=\"235\" width=\"60\" height=\"6\" rx=\"2\" fill=\"#8B6914\"/>\n  <rect x=\"370\" y=\"226\" width=\"60\" height=\"5\" rx=\"2\" fill=\"#8B6914\"/>\n  <rect x=\"372\" y=\"240\" width=\"6\" height=\"18\" rx=\"2\" fill=\"#6B4E14\"/>\n  <rect x=\"422\" y=\"240\" width=\"6\" height=\"18\" rx=\"2\" fill=\"#6B4E14\"/>\n  <rect x=\"367\" y=\"224\" width=\"8\" height=\"22\" rx=\"2\" fill=\"#6B4E14\"/>\n  <rect x=\"425\" y=\"224\" width=\"8\" height=\"22\" rx=\"2\" fill=\"#6B4E14\"/>\n  {/* Pond */}\n  <ellipse cx=\"120\" cy=\"268\" rx=\"55\" ry=\"22\" fill=\"#5B9BD5\" opacity=\"0.8\"/>\n  <ellipse cx=\"120\" cy=\"268\" rx=\"55\" ry=\"22\" fill=\"none\" stroke=\"#4A8BC0\" strokeWidth=\"2\" opacity=\"0.6\"/>\n  <ellipse cx=\"108\" cy=\"263\" rx=\"20\" ry=\"8\" fill=\"white\" opacity=\"0.15\"/>\n  {/* Ducks on pond */}\n  <ellipse cx=\"105\" cy=\"266\" rx=\"9\" ry=\"5\" fill=\"white\"/>\n  <circle cx=\"113\" cy=\"263\" r=\"5\" fill=\"white\"/>\n  <rect x=\"115\" y=\"261\" width=\"7\" height=\"3\" rx=\"1\" fill=\"#FFB900\"/>\n  <ellipse cx=\"130\" cy=\"270\" rx=\"8\" ry=\"4\" fill=\"white\"/>\n  <circle cx=\"137\" cy=\"267\" r=\"4\" fill=\"white\"/>\n  <rect x=\"139\" y=\"265\" width=\"6\" height=\"2.5\" rx=\"1\" fill=\"#FFB900\"/>\n</g>)"
}