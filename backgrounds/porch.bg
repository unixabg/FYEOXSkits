{
  "_type": "fyeox_background",
  "_version": "0.5.0",
  "id": "porch",
  "name": "Front Porch",
  "author": "unixabg@gmail.com",
  "created": "2026-04-23",
  "svg_component": "()=>(\n<g>\n  {/* Sky */}\n  <defs>\n    <linearGradient id=\"porchSkyG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#87CEEB\"/>\n      <stop offset=\"100%\" stopColor=\"#C8E8F8\"/>\n    </linearGradient>\n    <linearGradient id=\"woodG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#C4956A\"/>\n      <stop offset=\"100%\" stopColor=\"#A67B52\"/>\n    </linearGradient>\n  </defs>\n  <rect width=\"540\" height=\"320\" fill=\"url(#porchSkyG)\"/>\n\n  {/* House siding behind porch */}\n  <rect x=\"0\" y=\"0\" width=\"540\" height=\"220\" fill=\"#E8D8B8\"/>\n  {/* Horizontal siding lines */}\n  {[20,36,52,68,84,100,116,132,148,164,180,196,212].map((y,i)=>(\n    <line key={i} x1=\"0\" y1={y} x2=\"540\" y2={y} stroke=\"#D4C4A4\" strokeWidth=\"1.2\"/>\n  ))}\n\n  {/* House trim */}\n  <rect x=\"0\" y=\"0\" width=\"540\" height=\"12\" fill=\"#FFFFFF\"/>\n  <rect x=\"0\" y=\"208\" width=\"540\" height=\"14\" fill=\"#FFFFFF\"/>\n\n  {/* Windows */}\n  <rect x=\"60\" y=\"40\" width=\"90\" height=\"110\" rx=\"4\" fill=\"#7ABAFF\" opacity=\"0.5\" stroke=\"#FFFFFF\" strokeWidth=\"5\"/>\n  <rect x=\"60\" y=\"40\" width=\"90\" height=\"110\" rx=\"4\" fill=\"none\" stroke=\"#D4C4A4\" strokeWidth=\"3\"/>\n  <line x1=\"105\" y1=\"40\" x2=\"105\" y2=\"150\" stroke=\"#FFFFFF\" strokeWidth=\"4\"/>\n  <line x1=\"60\" y1=\"95\" x2=\"150\" y2=\"95\" stroke=\"#FFFFFF\" strokeWidth=\"4\"/>\n  {/* Window reflection */}\n  <rect x=\"65\" y=\"45\" width=\"18\" height=\"45\" fill=\"white\" opacity=\"0.15\" rx=\"2\"/>\n  {/* Window box with flowers */}\n  <rect x=\"55\" y=\"148\" width=\"100\" height=\"14\" rx=\"3\" fill=\"#8B4513\"/>\n  {[70,85,100,115,130].map((x,i)=>(\n    <g key={i}>\n      <line x1={x} y1=\"148\" x2={x} y2=\"138\" stroke=\"#3A8A28\" strokeWidth=\"2\"/>\n      <circle cx={x} cy=\"136\" r=\"6\" fill={[\"#FF6B6B\",\"#FFE900\",\"#FF88CC\",\"#FF6B6B\",\"#FFE900\"][i]}/>\n    </g>\n  ))}\n\n  <rect x=\"380\" y=\"40\" width=\"90\" height=\"110\" rx=\"4\" fill=\"#7ABAFF\" opacity=\"0.5\" stroke=\"#FFFFFF\" strokeWidth=\"5\"/>\n  <rect x=\"380\" y=\"40\" width=\"90\" height=\"110\" rx=\"4\" fill=\"none\" stroke=\"#D4C4A4\" strokeWidth=\"3\"/>\n  <line x1=\"425\" y1=\"40\" x2=\"425\" y2=\"150\" stroke=\"#FFFFFF\" strokeWidth=\"4\"/>\n  <line x1=\"380\" y1=\"95\" x2=\"470\" y2=\"95\" stroke=\"#FFFFFF\" strokeWidth=\"4\"/>\n  <rect x=\"385\" y=\"45\" width=\"18\" height=\"45\" fill=\"white\" opacity=\"0.15\" rx=\"2\"/>\n  <rect x=\"375\" y=\"148\" width=\"100\" height=\"14\" rx=\"3\" fill=\"#8B4513\"/>\n  {[390,405,420,435,450].map((x,i)=>(\n    <g key={i}>\n      <line x1={x} y1=\"148\" x2={x} y2=\"138\" stroke=\"#3A8A28\" strokeWidth=\"2\"/>\n      <circle cx={x} cy=\"136\" r=\"6\" fill={[\"#FF88CC\",\"#FFE900\",\"#FF6B6B\",\"#FFE900\",\"#FF88CC\"][i]}/>\n    </g>\n  ))}\n\n  {/* Front door */}\n  <rect x=\"220\" y=\"70\" width=\"100\" height=\"150\" rx=\"6\" fill=\"#8B3A1A\"/>\n  <rect x=\"225\" y=\"75\" width=\"90\" height=\"145\" rx=\"4\" fill=\"#A0451F\"/>\n  {/* Door panels */}\n  <rect x=\"230\" y=\"82\" width=\"38\" height=\"48\" rx=\"3\" fill=\"#8B3A1A\" stroke=\"#C4651A\" strokeWidth=\"1.5\"/>\n  <rect x=\"272\" y=\"82\" width=\"38\" height=\"48\" rx=\"3\" fill=\"#8B3A1A\" stroke=\"#C4651A\" strokeWidth=\"1.5\"/>\n  <rect x=\"230\" y=\"138\" width=\"38\" height=\"74\" rx=\"3\" fill=\"#8B3A1A\" stroke=\"#C4651A\" strokeWidth=\"1.5\"/>\n  <rect x=\"272\" y=\"138\" width=\"38\" height=\"74\" rx=\"3\" fill=\"#8B3A1A\" stroke=\"#C4651A\" strokeWidth=\"1.5\"/>\n  {/* Door knob */}\n  <circle cx=\"258\" cy=\"165\" r=\"5\" fill=\"#FFD700\"/>\n  {/* Door arch top */}\n  <rect x=\"216\" y=\"62\" width=\"108\" height=\"16\" rx=\"4\" fill=\"#FFFFFF\"/>\n  <rect x=\"220\" y=\"64\" width=\"100\" height=\"12\" rx=\"3\" fill=\"#7ABAFF\" opacity=\"0.5\"/>\n\n  {/* Porch roof / overhang */}\n  <rect x=\"0\" y=\"198\" width=\"540\" height=\"16\" fill=\"#FFFFFF\"/>\n  <polygon points=\"0,198 540,198 520,182 20,182\" fill=\"#E8E8E8\" stroke=\"#CCCCCC\" strokeWidth=\"1\"/>\n  {/* Roof shingles suggestion */}\n  {[0,60,120,180,240,300,360,420,480].map((x,i)=>(\n    <line key={i} x1={x} y1=\"182\" x2={x+40} y2=\"198\" stroke=\"#CCCCCC\" strokeWidth=\"1\" opacity=\"0.5\"/>\n  ))}\n\n  {/* Porch columns */}\n  <rect x=\"50\" y=\"182\" width=\"18\" height=\"138\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  <rect x=\"46\" y=\"182\" width=\"26\" height=\"10\" rx=\"2\" fill=\"#F0F0F0\"/>\n  <rect x=\"46\" y=\"316\" width=\"26\" height=\"4\" rx=\"2\" fill=\"#F0F0F0\"/>\n  <rect x=\"240\" y=\"182\" width=\"18\" height=\"138\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  <rect x=\"236\" y=\"182\" width=\"26\" height=\"10\" rx=\"2\" fill=\"#F0F0F0\"/>\n  <rect x=\"282\" y=\"182\" width=\"18\" height=\"138\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  <rect x=\"278\" y=\"182\" width=\"26\" height=\"10\" rx=\"2\" fill=\"#F0F0F0\"/>\n  <rect x=\"472\" y=\"182\" width=\"18\" height=\"138\" rx=\"4\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  <rect x=\"468\" y=\"182\" width=\"26\" height=\"10\" rx=\"2\" fill=\"#F0F0F0\"/>\n\n  {/* Porch railing */}\n  <rect x=\"0\" y=\"248\" width=\"540\" height=\"8\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  <rect x=\"0\" y=\"306\" width=\"540\" height=\"8\" rx=\"3\" fill=\"#FFFFFF\" stroke=\"#E0E0E0\" strokeWidth=\"1\"/>\n  {/* Balusters */}\n  {Array.from({length:36},(_,i)=>(\n    <rect key={i} x={8+i*15} y={254} width={6} height={54} rx=\"2\" fill=\"#FFFFFF\" stroke=\"#E8E8E8\" strokeWidth=\"0.5\"/>\n  ))}\n\n  {/* Porch floor boards */}\n  <rect x=\"0\" y=\"312\" width=\"540\" height=\"8\" fill=\"url(#woodG)\"/>\n  {[0,18,36,54,72,90,108,126,144,162,180,198,216,234,252,270,288,306,324,342,360,378,396,414,432,450,468,486,504,522].map((x,i)=>(\n    <line key={i} x1={x} y1=\"312\" x2={x} y2=\"320\" stroke=\"#9A7248\" strokeWidth=\"1\" opacity=\"0.6\"/>\n  ))}\n\n  {/* Rocking chair left side */}\n  <g transform=\"translate(100,258)\">\n    <rect x=\"0\" y=\"0\" width=\"52\" height=\"5\" rx=\"2\" fill=\"#8B6914\"/>\n    <rect x=\"4\" y=\"-32\" width=\"44\" height=\"5\" rx=\"2\" fill=\"#8B6914\"/>\n    {[6,16,26,36,46].map((x,i)=>(\n      <rect key={i} x={x} y={-32} width={4} height={37} rx=\"1\" fill=\"#A07820\"/>\n    ))}\n    <rect x=\"0\" y={-50} width=\"52\" height=\"22\" rx=\"4\" fill=\"#8B6914\"/>\n    <rect x=\"-5\" y={-32} width=\"8\" height=\"45\" rx=\"3\" fill=\"#8B6914\"/>\n    <rect x=\"49\" y={-32} width=\"8\" height=\"45\" rx=\"3\" fill=\"#8B6914\"/>\n    <path d=\"M-5 13 Q26 22 57 13\" stroke=\"#8B6914\" strokeWidth=\"5\" fill=\"none\" strokeLinecap=\"round\"/>\n    <path d=\"M2 13 Q26 20 50 13\" stroke=\"#6B4E10\" strokeWidth=\"3\" fill=\"none\" strokeLinecap=\"round\"/>\n  </g>\n\n  {/* Potted plants */}\n  <rect x=\"430\" y=\"288\" width=\"32\" height=\"22\" rx=\"4\" fill=\"#C4651A\"/>\n  <rect x=\"428\" y=\"286\" width=\"36\" height=\"6\" rx=\"2\" fill=\"#A0451F\"/>\n  <ellipse cx=\"446\" cy=\"286\" rx=\"20\" ry=\"14\" fill=\"#2D6A1F\"/>\n  <ellipse cx=\"438\" cy=\"280\" rx=\"14\" ry=\"10\" fill=\"#3A8A28\"/>\n  <ellipse cx=\"454\" cy=\"278\" rx=\"12\" ry=\"9\" fill=\"#2D6A1F\"/>\n\n  {/* Welcome mat */}\n  <rect x=\"200\" y=\"306\" width=\"140\" height=\"10\" rx=\"3\" fill=\"#8B4513\"/>\n  <rect x=\"204\" y=\"308\" width=\"132\" height=\"6\" rx=\"2\" fill=\"#A0522D\"/>\n  <text x=\"270\" y=\"315\" textAnchor=\"middle\" fontSize=\"7\" fill=\"#FFD700\" fontFamily=\"'Comic Sans MS',cursive\" fontWeight=\"bold\">WELCOME</text>\n\n  {/* Front yard grass */}\n  <rect x=\"0\" y=\"318\" width=\"540\" height=\"2\" fill=\"#3A7A2F\"/>\n</g>)"
}