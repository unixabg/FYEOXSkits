{
  "_type": "fyeox_background",
  "_version": "0.5.3",
  "id": "default",
  "name": "Default (Free)",
  "author": "unixabg@gmail.com",
  "created": "2026-04-27",
  "svg_component": "()=>(\n<g>\n  <defs>\n    <linearGradient id=\"dfSky\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#3A9AD9\"/>\n      <stop offset=\"65%\" stopColor=\"#87CEEB\"/>\n      <stop offset=\"100%\" stopColor=\"#C8E8F5\"/>\n    </linearGradient>\n    <linearGradient id=\"dfGrass\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#5CB85C\"/>\n      <stop offset=\"100%\" stopColor=\"#3A8A3A\"/>\n    </linearGradient>\n    <linearGradient id=\"dfPath\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#D4C4A8\"/>\n      <stop offset=\"100%\" stopColor=\"#B8A88C\"/>\n    </linearGradient>\n  </defs>\n\n  {/* Sky */}\n  <rect width=\"540\" height=\"230\" fill=\"url(#dfSky)\"/>\n\n  {/* Distant rolling hills */}\n  <ellipse cx=\"130\" cy=\"228\" rx=\"200\" ry=\"55\" fill=\"#6BBF6B\" opacity=\"0.55\"/>\n  <ellipse cx=\"420\" cy=\"232\" rx=\"210\" ry=\"50\" fill=\"#5AAF5A\" opacity=\"0.5\"/>\n\n  {/* Ground */}\n  <rect y=\"210\" width=\"540\" height=\"110\" fill=\"url(#dfGrass)\"/>\n\n  {/* Centre path / sidewalk */}\n  <rect x=\"162\" y=\"210\" width=\"216\" height=\"110\" fill=\"url(#dfPath)\"/>\n  <line x1=\"270\" y1=\"215\" x2=\"270\" y2=\"320\" stroke=\"#C0AA8A\" strokeWidth=\"1.5\" strokeDasharray=\"12,8\" opacity=\"0.45\"/>\n\n  {/* Sun */}\n  <circle cx=\"470\" cy=\"50\" r=\"34\" fill=\"#FFE066\" opacity=\"0.28\"/>\n  <circle cx=\"470\" cy=\"50\" r=\"24\" fill=\"#FFD700\" opacity=\"0.55\"/>\n  <circle cx=\"470\" cy=\"50\" r=\"17\" fill=\"#FFE900\"/>\n\n  {/* Cloud 1 (large, left) */}\n  <g opacity=\"0.93\">\n    <ellipse cx=\"86\" cy=\"64\" rx=\"48\" ry=\"24\" fill=\"white\"/>\n    <ellipse cx=\"58\"  cy=\"74\" rx=\"29\" ry=\"20\" fill=\"white\"/>\n    <ellipse cx=\"120\" cy=\"72\" rx=\"33\" ry=\"20\" fill=\"white\"/>\n  </g>\n\n  {/* Cloud 2 (small, centre) */}\n  <g opacity=\"0.87\">\n    <ellipse cx=\"316\" cy=\"50\" rx=\"36\" ry=\"17\" fill=\"white\"/>\n    <ellipse cx=\"292\" cy=\"59\" rx=\"21\" ry=\"14\" fill=\"white\"/>\n    <ellipse cx=\"342\" cy=\"58\" rx=\"25\" ry=\"14\" fill=\"white\"/>\n  </g>\n\n  {/* Tree — left */}\n  <rect x=\"54\"  y=\"160\" width=\"10\" height=\"65\" rx=\"3\" fill=\"#8B5A2B\"/>\n  <ellipse cx=\"59\"  cy=\"143\" rx=\"33\" ry=\"37\" fill=\"#2E7D32\"/>\n  <ellipse cx=\"38\"  cy=\"158\" rx=\"20\" ry=\"25\" fill=\"#388E3C\"/>\n  <ellipse cx=\"81\"  cy=\"155\" rx=\"23\" ry=\"27\" fill=\"#2E7D32\"/>\n  <ellipse cx=\"59\"  cy=\"122\" rx=\"22\" ry=\"25\" fill=\"#43A047\"/>\n\n  {/* Tree — right */}\n  <rect x=\"464\" y=\"168\" width=\"9\"  height=\"56\" rx=\"3\" fill=\"#8B5A2B\"/>\n  <ellipse cx=\"468\" cy=\"152\" rx=\"28\" ry=\"31\" fill=\"#388E3C\"/>\n  <ellipse cx=\"449\" cy=\"165\" rx=\"18\" ry=\"21\" fill=\"#2E7D32\"/>\n  <ellipse cx=\"487\" cy=\"162\" rx=\"21\" ry=\"23\" fill=\"#388E3C\"/>\n  <ellipse cx=\"468\" cy=\"136\" rx=\"18\" ry=\"21\" fill=\"#43A047\"/>\n\n  {/* Picket fence — left of path */}\n  <line x1=\"100\" y1=\"208\" x2=\"162\" y2=\"208\" stroke=\"#D4A85A\" strokeWidth=\"5\" strokeLinecap=\"round\"/>\n  <rect x=\"100\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"103,196 100,202 106,202\" fill=\"#E8BC6A\"/>\n  <rect x=\"120\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"123,196 120,202 126,202\" fill=\"#E8BC6A\"/>\n  <rect x=\"140\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"143,196 140,202 146,202\" fill=\"#E8BC6A\"/>\n\n  {/* Picket fence — right of path */}\n  <line x1=\"378\" y1=\"208\" x2=\"440\" y2=\"208\" stroke=\"#D4A85A\" strokeWidth=\"5\" strokeLinecap=\"round\"/>\n  <rect x=\"378\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"381,196 378,202 384,202\" fill=\"#E8BC6A\"/>\n  <rect x=\"398\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"401,196 398,202 404,202\" fill=\"#E8BC6A\"/>\n  <rect x=\"418\" y=\"196\" width=\"6\" height=\"26\" rx=\"2\" fill=\"#D4A85A\" stroke=\"#B88A3A\" strokeWidth=\"1\"/>\n  <polygon points=\"421,196 418,202 424,202\" fill=\"#E8BC6A\"/>\n\n  {/* FYEOX sign post — far left background */}\n  <rect x=\"25\"  y=\"224\" width=\"5\" height=\"44\" rx=\"1\" fill=\"#7A4A1A\"/>\n  <rect x=\"10\"  y=\"168\" width=\"60\" height=\"30\" rx=\"5\" fill=\"#0A0E1A\" stroke=\"#FFE900\" strokeWidth=\"2\"/>\n  <text x=\"40\" y=\"181\" textAnchor=\"middle\" fontSize=\"8\" fontFamily=\"'Comic Sans MS',cursive\" fontWeight=\"bold\" fill=\"#FFE900\">🎭 FYEOX</text>\n  <text x=\"40\" y=\"191\" textAnchor=\"middle\" fontSize=\"6.5\" fontFamily=\"'Comic Sans MS',cursive\" fill=\"#8ABACC\">fyeox.com</text>\n  <polygon points=\"27,224 40,213 53,224\" fill=\"#0A0E1A\" stroke=\"#FFE900\" strokeWidth=\"1.5\"/>\n\n  {/* Bottom watermark strip */}\n  <rect x=\"0\" y=\"304\" width=\"540\" height=\"16\" fill=\"rgba(0,0,0,0.5)\"/>\n  <text x=\"270\" y=\"315\" textAnchor=\"middle\" fontSize=\"8.5\" fontFamily=\"'Comic Sans MS',cursive\" fontWeight=\"bold\" fill=\"rgba(255,233,0,0.9)\">\n    FREE VERSION — More characters, backgrounds, custom themes {\"&\"} support at fyeox.com\n  </text>\n</g>\n)"
}