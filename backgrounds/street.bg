{
  "_type": "fyeox_background",
  "_version": "0.5.0",
  "id": "street",
  "name": "Night Street Scene",
  "author": "unixabg@gmail.com",
  "created": "2026-04-23",
  "svg_component": "()=>(\n<g>\n  {/* Night sky */}\n  <defs>\n    <linearGradient id=\"nightG\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n      <stop offset=\"0%\" stopColor=\"#0A0A2A\"/>\n      <stop offset=\"100%\" stopColor=\"#1A1A4A\"/>\n    </linearGradient>\n  </defs>\n  <rect width=\"540\" height=\"320\" fill=\"url(#nightG)\"/>\n  {/* Moon */}\n  <circle cx=\"460\" cy=\"48\" r=\"28\" fill=\"#FFFACC\"/>\n  <circle cx=\"472\" cy=\"40\" r=\"22\" fill=\"#1A1A3A\"/>\n  {/* Stars */}\n  {[[30,20],[80,35],[140,15],[200,40],[250,18],[300,30],[350,12],[400,38],[50,60],[120,55],[180,65],[280,50],[380,58],[480,25],[510,45]].map(([x,y],i)=>(\n    <circle key={i} cx={x} cy={y} r={1.5+(i%3)*0.5} fill=\"white\" opacity={0.6+(i%4)*0.1}/>\n  ))}\n  {/* Buildings - dark at night with lit windows */}\n  <rect x=\"0\" y=\"30\" width=\"100\" height=\"190\" fill=\"#1A1A2E\" stroke=\"#2A2A4E\" strokeWidth=\"1\"/>\n  <rect x=\"8\" y=\"42\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.8\"/>\n  <rect x=\"28\" y=\"42\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.5\"/>\n  <rect x=\"48\" y=\"42\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"68\" y=\"42\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"8\" y=\"70\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"28\" y=\"70\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.7\"/>\n  <rect x=\"48\" y=\"70\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.8\"/>\n  <rect x=\"68\" y=\"70\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.4\"/>\n  <rect x=\"8\" y=\"98\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.6\"/>\n  <rect x=\"28\" y=\"98\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"48\" y=\"98\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"68\" y=\"98\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"100\" y=\"60\" width=\"130\" height=\"160\" fill=\"#16213E\" stroke=\"#2A2A4E\" strokeWidth=\"1\"/>\n  <rect x=\"108\" y=\"72\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.7\"/>\n  <rect x=\"132\" y=\"72\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"156\" y=\"72\" width=\"16\" height=\"18\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"180\" y=\"72\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.6\"/>\n  <rect x=\"108\" y=\"102\" width=\"16\" height=\"18\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"132\" y=\"102\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.8\"/>\n  <rect x=\"156\" y=\"102\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.5\"/>\n  <rect x=\"180\" y=\"102\" width=\"16\" height=\"18\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"108\" y=\"132\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"132\" y=\"132\" width=\"16\" height=\"18\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"156\" y=\"132\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.7\"/>\n  <rect x=\"180\" y=\"132\" width=\"16\" height=\"18\" fill=\"#FFE066\" opacity=\"0.4\"/>\n  <rect x=\"350\" y=\"45\" width=\"110\" height=\"175\" fill=\"#1A1A2E\" stroke=\"#2A2A4E\" strokeWidth=\"1\"/>\n  <rect x=\"358\" y=\"58\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"378\" y=\"58\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.8\"/>\n  <rect x=\"398\" y=\"58\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.6\"/>\n  <rect x=\"418\" y=\"58\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"438\" y=\"58\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"358\" y=\"86\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.5\"/>\n  <rect x=\"378\" y=\"86\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"398\" y=\"86\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.7\"/>\n  <rect x=\"438\" y=\"86\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.4\"/>\n  <rect x=\"460\" y=\"50\" width=\"80\" height=\"170\" fill=\"#16213E\" stroke=\"#2A2A4E\" strokeWidth=\"1\"/>\n  <rect x=\"468\" y=\"62\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.9\"/>\n  <rect x=\"490\" y=\"62\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.4\"/>\n  <rect x=\"512\" y=\"62\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.7\"/>\n  <rect x=\"468\" y=\"90\" width=\"14\" height=\"16\" fill=\"#334\" opacity=\"0.3\"/>\n  <rect x=\"490\" y=\"90\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.8\"/>\n  <rect x=\"512\" y=\"90\" width=\"14\" height=\"16\" fill=\"#FFE066\" opacity=\"0.5\"/>\n  {/* Storefronts at street level */}\n  <rect x=\"0\" y=\"188\" width=\"100\" height=\"32\" fill=\"#2A1A00\"/>\n  <rect x=\"5\" y=\"193\" width=\"90\" height=\"22\" fill=\"#FF8800\" opacity=\"0.3\"/>\n  <text x=\"50\" y=\"208\" textAnchor=\"middle\" fontSize=\"8\" fill=\"#FFD700\" fontFamily=\"'Comic Sans MS',cursive\">DINER</text>\n  <rect x=\"100\" y=\"195\" width=\"130\" height=\"25\" fill=\"#001A2A\"/>\n  <rect x=\"105\" y=\"199\" width=\"120\" height=\"16\" fill=\"#0044AA\" opacity=\"0.4\"/>\n  <text x=\"165\" y=\"211\" textAnchor=\"middle\" fontSize=\"8\" fill=\"#88CCFF\" fontFamily=\"'Comic Sans MS',cursive\">HARDWARE</text>\n  <rect x=\"350\" y=\"188\" width=\"110\" height=\"32\" fill=\"#1A0022\"/>\n  <rect x=\"355\" y=\"193\" width=\"100\" height=\"22\" fill=\"#9900CC\" opacity=\"0.25\"/>\n  <text x=\"405\" y=\"208\" textAnchor=\"middle\" fontSize=\"8\" fill=\"#CC88FF\" fontFamily=\"'Comic Sans MS',cursive\">ARCADE</text>\n  <rect x=\"460\" y=\"188\" width=\"80\" height=\"32\" fill=\"#001A00\"/>\n  <rect x=\"465\" y=\"193\" width=\"70\" height=\"22\" fill=\"#009900\" opacity=\"0.25\"/>\n  <text x=\"500\" y=\"208\" textAnchor=\"middle\" fontSize=\"8\" fill=\"#66FF66\" fontFamily=\"'Comic Sans MS',cursive\">MARKET</text>\n  {/* Sidewalk */}\n  <rect x=\"0\" y=\"218\" width=\"540\" height=\"22\" fill=\"#2A2A3A\"/>\n  {/* Road */}\n  <rect x=\"0\" y=\"240\" width=\"540\" height=\"80\" fill=\"#1A1A1A\"/>\n  {/* Road markings */}\n  <rect x=\"0\" y=\"278\" width=\"540\" height=\"4\" fill=\"#888\" opacity=\"0.5\"/>\n  {[0,60,120,180,240,300,360,420,480].map((x,i)=>(\n    <rect key={i} x={x} y=\"276\" width=\"40\" height=\"8\" rx=\"2\" fill=\"#FFE900\" opacity=\"0.8\"/>\n  ))}\n  {/* Streetlamps */}\n  {[80,260,440].map((x,i)=>(\n    <g key={i}>\n      <rect x={x} y={185} width={5} height={55} fill=\"#888\"/>\n      <path d={`M${x+2} ${185} Q${x+22} ${175} ${x+26} ${185}`} stroke=\"#888\" strokeWidth=\"4\" fill=\"none\"/>\n      <ellipse cx={x+26} cy={184} rx={10} ry={6} fill=\"#FFFAAA\" opacity=\"0.9\"/>\n      <ellipse cx={x+26} cy={184} rx={14} ry={10} fill=\"#FFFAAA\" opacity=\"0.15\"/>\n    </g>\n  ))}\n</g>)"
}